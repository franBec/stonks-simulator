{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "java",
      "name": "Stonks Java (no external deps needed)",
      "request": "launch",
      "mainClass": "dev.pollito.stonks_java.StonksJavaApplication",
      "projectName": "stonks_java",
      "preLaunchTask": "gradle-compile-java",
      "cwd": "${workspaceFolder}/stonks_java"
    },
    {
      "type": "java",
      "name": "Stonks Java (Pollito preferences for local development)",
      "request": "launch",
      "mainClass": "dev.pollito.stonks_java.StonksJavaApplication",
      "projectName": "stonks_java",
      "preLaunchTask": "gradle-compile-java",
      "args": [
        "--stonks.adapters.cobol=real",
        "--stonks.adapters.ai=real",
        "--stonks.adapters.news=real",
        "--spring.profiles.active=local"
      ],
      "cwd": "${workspaceFolder}/stonks_java"
    },
    {
      "type": "chrome",
      "request": "launch",
      "name": "Stonks Java Open JaCoCo Report",
      "file": "${workspaceFolder}/stonks_java/build/reports/jacoco/test/html/index.html"
    },
    {
      "type": "chrome",
      "request": "launch",
      "name": "Stonks Java Open Karate Report",
      "file": "${workspaceFolder}/stonks_java/target/karate-reports/karate-summary.html"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Stonks Vite App",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "${workspaceFolder}/stonks_vite_app",
      "console": "integratedTerminal"
    }
  ]
}
