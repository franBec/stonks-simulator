{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "java",
      "name": "[local] Stonks (H2 + stubs)",
      "request": "launch",
      "mainClass": "dev.pollito.stonks_java.StonksJavaApplication",
      "projectName": "stonks_java",
      "cwd": "${workspaceFolder}/stonks_java"
    },
    {
      "type": "java",
      "name": "[cobol] Stonks (H2 + real COBOL)",
      "request": "launch",
      "mainClass": "dev.pollito.stonks_java.StonksJavaApplication",
      "projectName": "stonks_java",
      "env": {
        "SPRING_PROFILES_ACTIVE": "cobol"
      },
      "cwd": "${workspaceFolder}/stonks_java"
    },
    {
      "type": "java",
      "name": "[production] Stonks (PG + real COBOL + OTel)",
      "request": "launch",
      "mainClass": "dev.pollito.stonks_java.StonksJavaApplication",
      "projectName": "stonks_java",
      "env": {
        "SPRING_PROFILES_ACTIVE": "production"
      },
      "cwd": "${workspaceFolder}/stonks_java"
    },
    {
      "type": "chrome",
      "request": "launch",
      "name": "Open JaCoCo Report",
      "file": "${workspaceFolder}/stonks_java/build/reports/jacoco/test/html/index.html"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Vite Dev Server (pnpm)",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "${workspaceFolder}/stonks_vite_app",
      "console": "integratedTerminal"
    }
  ]
}
